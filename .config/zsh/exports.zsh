# =========================
# Exports
# =========================

export EDITOR="nano"
export VISUAL="nano"
export PAGER="less"

# Colors
export CLICOLOR=1
export LSCOLORS=GxFxCxDxBxegedabagaced

# Less better
export LESS="-R -F -X"

# Better grep
export GREP_OPTIONS="--color=auto"


export PATH="$JAVA_HOME/bin:/opt/homebrew/opt/openjdk@21/bin:$PATH"
export JAVA_HOME=$(/usr/libexec/java_home)
