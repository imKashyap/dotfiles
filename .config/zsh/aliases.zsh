# =========================
# Aliases
# =========================

alias ll="ls -lah"
alias la="ls -A"
alias ..="cd .."
alias ...="cd ../.."

# Git shortcuts
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gco="git checkout"
alias gp="git push"
alias gl="git log --oneline --graph --decorate --all"

# Tmux
alias t="tmux"
alias ta="tmux attach -t"
alias tls="tmux ls"

alias zshconfig="nano ~/.zshrc"
alias dot='/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'

